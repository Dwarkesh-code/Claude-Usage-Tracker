{
  "manifest_version": 3,
  "name": "Claude Usage Tracker",
  "version": "2.1.0",
  "description": "Real-time session and context tracking for claude.ai",
  "permissions": ["storage", "clipboardWrite", "tabs"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://*.claude.ai/*"
  ],
  "action": {
    "default_title": "Claude Usage Tracker",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*", "https://*.claude.ai/*"],
      "js": ["injector.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://claude.ai/*", "https://*.claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://claude.ai/*", "https://*.claude.ai/*"]
    }
  ]
}
